{
	"compilerOptions": {
		"baseUrl": "src",
		"inlineSourceMap": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"allowSyntheticDefaultImports": true,
		"lib": ["DOM", "ES5", "ES6", "ES7"]
	},
	"include": ["src/**/*.ts"]
}
